# Contract addresses (required after deploying with script/DeploySepolia.s.sol or Deploy.s.sol)
VITE_VAULT_ADDRESS=0x...
VITE_ZAP_ADDRESS=0x...

# Optional: override token addresses (defaults to Sepolia WETH/USDC from DeploySepolia.s.sol)
# VITE_WETH_ADDRESS=0xfFf9976782d46CC05630D1f6eBAb18b2324d6B14
# VITE_USDC_ADDRESS=0x1c7D4B196Cb0C7B01d743Fbc6116a902379C7238

# Optional: PoolManager address for "Initialize pool" on Admin (Sepolia has a default; set for other chains)
# VITE_POOL_MANAGER_ADDRESS=0xE03A1074c86CFeDd5C142C4F04F1a1536e203543

# Optional: Uniswap v4 Quoter for exact zap-out amounts (ETH only / USDC only). Base mainnet has a default.
# VITE_QUOTER_ADDRESS=0x0d5e0F971ED27FBfF6c2837bf31316121532048D

# Optional: chain (default 11155111 = Sepolia)
# VITE_CHAIN_ID=11155111

# Optional: RPC URL for all chains (defaults: Base, Base Sepolia, Sepolia public RPCs)
# VITE_RPC_URL=https://rpc.sepolia.org

# Optional: WalletConnect Project ID (from https://cloud.walletconnect.com) to show WalletConnect in the wallet modal
# VITE_WALLETCONNECT_PROJECT_ID=your_project_id

# Optional: Backend API URL for admin whitelist list (e.g. http://localhost:4000)
# VITE_API_URL=http://localhost:4000
# Optional: Same as backend ADMIN_SECRET — required for whitelist add/remove sync when backend has ADMIN_SECRET set
# VITE_ADMIN_SECRET=
